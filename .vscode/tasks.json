{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start NexoPost Dev (3001)",
      "type": "shell",
      "command": "${workspaceFolder}/start-nexopost-dev.command",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".*"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*(Starting NexoPost dev server|Port 3001 is already active).*",
          "endsPattern": ".*(Ready in|Port 3001 is already active).*"
        }
      }
    }
  ]
}
