# Required
APP_BASE_URL=http://localhost:3001
AUTH_SECRET=replace-with-a-long-random-secret
DATABASE_URL=mysql://user:password@127.0.0.1:3306/nexopost

# Optional URL aliases
NEXTAUTH_URL=http://localhost:3001
NEXOPOST_APP_URL=http://localhost:3001

# Access control
# Comma separated emails, example: admin1@example.com,admin2@example.com
ADMIN_EMAILS=
SUPERADMIN_EMAILS=

# Cron
CRON_SECRET=replace-with-random-cron-secret

# Billing (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Social OAuth (optional)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# Media upload (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Support mailbox / outbound email (optional)
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_MAIL_SENDER=
SUPPORT_NOTIFICATION_EMAIL=
