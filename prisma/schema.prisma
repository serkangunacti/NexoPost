generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  EDITOR
  APPROVER
  VIEWER
}

enum SocialAccountStatus {
  CONNECTED
  DISCONNECTED
  EXPIRED
  ERROR
}

enum WorkspaceStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PublicationJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  PARTIAL
  CANCELLED
  BLOCKED_QUOTA
  BLOCKED_X_BUDGET
  BLOCKED_PLAN_ACCESS
  BLOCKED_DAILY_CAP
}

model Post {
  id                 String              @id @default(uuid())
  content            String              @db.Text
  platforms          Json
  platformConfig     Json?               @map("platform_config")
  status             String              @default("Draft")
  date               String
  time               String
  scheduledAt        DateTime?           @map("scheduled_at")
  autoOptimize       Boolean             @default(false) @map("auto_optimize")
  mediaUrls          Json                @map("media_urls")
  userId             String              @map("user_id")
  workspaceId        String?             @map("workspace_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  author             User                @relation("PostAuthor", fields: [userId], references: [id], onDelete: Cascade)
  workspace          Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  approvalRequests   ApprovalRequest[]
  mediaAssets        MediaAsset[]
  publicationJobs    PublicationJob[]
  publicationResults PublicationResult[]
  variants           PostVariant[]

  @@index([workspaceId, createdAt])
  @@map("posts")
}

model User {
  id                        String            @id @default(cuid())
  email                     String?           @unique
  hashedPassword            String?           @map("hashed_password")
  userType                  String            @default("basic") @map("user_type")
  superadminNote            String?           @map("superadmin_note") @db.Text
  activeClientId            String?           @map("active_client_id")
  clients                   Json              @default("[]")
  connectedAccounts         Json              @default("{}") @map("connected_accounts")
  socialTokens              Json?             @map("social_tokens")
  subscription              Json?
  pendingChange             Json?             @map("pending_change")
  userProfile               Json?             @map("user_profile")
  createdAt                 DateTime          @default(now()) @map("created_at")
  updatedAt                 DateTime          @updatedAt @map("updated_at")
  approvalRequestsRequested ApprovalRequest[] @relation("ApprovalRequester")
  approvalRequestsReviewed  ApprovalRequest[] @relation("ApprovalReviewer")
  auditLogs                 AuditLog[]
  postsAuthored             Post[]            @relation("PostAuthor")
  supportRequests           SupportRequest[]
  workspaceMemberships      WorkspaceMember[]
  workspacesOwned           Workspace[]       @relation("WorkspaceOwner")

  @@map("users")
}

model Workspace {
  id                 String              @id @default(cuid())
  name               String
  slug               String?             @unique
  status             WorkspaceStatus     @default(ACTIVE)
  ownerId            String              @map("owner_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  approvalRequests   ApprovalRequest[]
  auditLogs          AuditLog[]
  brandProfile       BrandProfile?
  members            WorkspaceMember[]
  owner              User                @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  posts              Post[]
  publicationJobs    PublicationJob[]
  publicationResults PublicationResult[]
  socialAccounts     SocialAccount[]
  subscriptions      Subscription[]
  supportRequests    SupportRequest[]
  usagePeriods       WorkspaceUsagePeriod[]
  dailyUsage         WorkspaceDailyUsage[]

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole @default(EDITOR)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model BrandProfile {
  id              String    @id @default(cuid())
  workspaceId     String    @unique @map("workspace_id")
  logoUrl         String?   @map("logo_url")
  domain          String?   @unique
  primaryColor    String?   @map("primary_color")
  emailSender     String?   @map("email_sender")
  customLoginCopy String?   @map("custom_login_copy") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("brand_profiles")
}

model SocialAccount {
  id                String              @id @default(cuid())
  workspaceId       String              @map("workspace_id")
  platform          String
  externalAccountId String              @map("external_account_id")
  displayName       String              @map("display_name")
  avatarUrl         String?             @map("avatar_url")
  accessToken       String?             @map("access_token") @db.Text
  refreshToken      String?             @map("refresh_token") @db.Text
  tokenExpiresAt    DateTime?           @map("token_expires_at")
  scopes            Json?
  pageId            String?             @map("page_id")
  pageName          String?             @map("page_name")
  pageAccessToken   String?             @map("page_access_token") @db.Text
  status            SocialAccountStatus @default(CONNECTED)
  metadata          Json?
  connectedAt       DateTime            @default(now()) @map("connected_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  publicationJobs   PublicationJob[]
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform])
  @@index([platform, status])
  @@map("social_accounts")
}

model MediaAsset {
  id           String   @id @default(cuid())
  postId       String   @map("post_id")
  kind         String
  url          String
  thumbnailUrl String?  @map("thumbnail_url")
  mimeType     String?  @map("mime_type")
  sizeBytes    Int?     @map("size_bytes")
  width        Int?
  height       Int?
  durationMs   Int?     @map("duration_ms")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
  @@map("media_assets")
}

model PostVariant {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  platform  String
  content   String   @db.Text
  mediaUrls Json?    @map("media_urls")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, platform])
  @@index([platform])
  @@map("post_variants")
}

model ApprovalRequest {
  id            String                @id @default(cuid())
  postId        String                @map("post_id")
  workspaceId   String                @map("workspace_id")
  requestedById String                @map("requested_by_id")
  reviewerId    String?               @map("reviewer_id")
  status        ApprovalRequestStatus @default(PENDING)
  comment       String?               @db.Text
  requestedAt   DateTime              @default(now()) @map("requested_at")
  decidedAt     DateTime?             @map("decided_at")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  post          Post                  @relation(fields: [postId], references: [id], onDelete: Cascade)
  requestedBy   User                  @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewer      User?                 @relation("ApprovalReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  workspace     Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([requestedById])
  @@index([reviewerId])
  @@map("approval_requests")
}

model PublicationJob {
  id              String               @id @default(cuid())
  postId          String               @map("post_id")
  workspaceId     String               @map("workspace_id")
  socialAccountId String?              @map("social_account_id")
  platform        String
  status          PublicationJobStatus @default(PENDING)
  attempts        Int                  @default(0)
  maxAttempts     Int                  @default(5) @map("max_attempts")
  scheduledFor    DateTime?            @map("scheduled_for")
  startedAt       DateTime?            @map("started_at")
  finishedAt      DateTime?            @map("finished_at")
  lastError       String?              @map("last_error") @db.Text
  quotaChargedAt  DateTime?            @map("quota_charged_at")
  quotaChargeUnits Int                 @default(0) @map("quota_charge_units")
  xSpendChargedCents Int               @default(0) @map("x_spend_charged_cents")
  payload         Json?
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  post            Post                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  result          PublicationResult?
  socialAccount   SocialAccount?       @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  workspace       Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([workspaceId, platform])
  @@map("publication_jobs")
}

model PublicationResult {
  id           String               @id @default(cuid())
  jobId        String               @unique @map("job_id")
  postId       String               @map("post_id")
  workspaceId  String               @map("workspace_id")
  platform     String
  status       PublicationJobStatus
  remoteId     String?              @map("remote_id")
  remoteUrl    String?              @map("remote_url")
  payload      Json?
  errorMessage String?              @map("error_message") @db.Text
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  job          PublicationJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  post         Post                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, platform, status])
  @@map("publication_results")
}

model Subscription {
  id                 String    @id @default(cuid())
  workspaceId        String    @map("workspace_id")
  provider           String    @default("stripe")
  externalId         String?   @map("external_id")
  plan               String
  status             String
  billingCycle       String    @map("billing_cycle")
  trialEndsAt        DateTime? @map("trial_ends_at")
  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")
  seats              Int       @default(1)
  metadata           Json?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@map("subscriptions")
}

model WorkspaceUsagePeriod {
  id                    String    @id @default(cuid())
  workspaceId           String    @map("workspace_id")
  plan                  String
  billingCycle          String    @map("billing_cycle")
  periodStart           DateTime  @map("period_start")
  periodEnd             DateTime  @map("period_end")
  platformJobsIncluded  Int?      @map("platform_jobs_included")
  platformJobsUsed      Int       @default(0) @map("platform_jobs_used")
  platformJobsBlocked   Int       @default(0) @map("platform_jobs_blocked")
  xSpendCapCents        Int?      @map("x_spend_cap_cents")
  xSpendUsedCents       Int       @default(0) @map("x_spend_used_cents")
  xSpendBlockedCents    Int       @default(0) @map("x_spend_blocked_cents")
  perPlatformMonthlyCounts Json?  @map("per_platform_monthly_counts")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, periodStart, periodEnd])
  @@index([workspaceId, periodEnd])
  @@map("workspace_usage_periods")
}

model WorkspaceDailyUsage {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  date        DateTime
  platform    String
  usedJobs    Int       @default(0) @map("used_jobs")
  blockedJobs Int       @default(0) @map("blocked_jobs")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, date, platform])
  @@index([workspaceId, date])
  @@map("workspace_daily_usage")
}

model DiscountCode {
  id                  String   @id @default(cuid())
  code                String   @unique
  percentOff          Int      @map("percent_off")
  startsAt            DateTime? @map("starts_at")
  expiresAt           DateTime? @map("expires_at")
  maxRedemptions      Int?     @map("max_redemptions")
  redeemedCount       Int      @default(0) @map("redeemed_count")
  allowedPlans        Json?    @map("allowed_plans")
  allowedBillingCycles Json?   @map("allowed_billing_cycles")
  isActive            Boolean  @default(true) @map("is_active")
  metadata            Json?
  createdById         String?  @map("created_by_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  redemptions         DiscountRedemption[]

  @@index([isActive, expiresAt])
  @@map("discount_codes")
}

model DiscountRedemption {
  id             String   @id @default(cuid())
  discountCodeId String   @map("discount_code_id")
  userId         String?  @map("user_id")
  email          String?
  plan           String
  billingCycle   String   @map("billing_cycle")
  percentOff     Int      @map("percent_off")
  redeemedAt     DateTime @default(now()) @map("redeemed_at")
  orderContext   Json?    @map("order_context")
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)

  @@index([discountCodeId, redeemedAt])
  @@index([userId, redeemedAt])
  @@map("discount_redemptions")
}

model XRateCard {
  id                 String   @id @default(cuid())
  code               String   @unique
  version            String
  estimatedCostCents Int      @map("estimated_cost_cents")
  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([active, code])
  @@map("x_rate_cards")
}

model AuditLog {
  id          String     @id @default(cuid())
  userId      String?    @map("user_id")
  workspaceId String?    @map("workspace_id")
  action      String
  entityType  String     @map("entity_type")
  entityId    String?    @map("entity_id")
  payload     Json?
  createdAt   DateTime   @default(now()) @map("created_at")
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model SupportRequest {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  workspaceId String?   @map("workspace_id")
  subject     String
  message     String    @db.Text
  status      String    @default("OPEN")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([status, createdAt])
  @@map("support_requests")
}
